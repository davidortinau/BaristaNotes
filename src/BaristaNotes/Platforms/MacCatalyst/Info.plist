<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- The Mac App Store requires you specify if the app uses encryption. -->
    <!-- Please consult https://developer.apple.com/documentation/bundleresources/information_property_list/itsappusesnonexemptencryption -->
    <!-- <key>ITSAppUsesNonExemptEncryption</key> -->
    <!-- Please indicate <true/> or <false/> here. -->

    <!-- Specify the category for your app here. -->
    <!-- Please consult https://developer.apple.com/documentation/bundleresources/information_property_list/lsapplicationcategorytype -->
    <!-- <key>LSApplicationCategoryType</key> -->
    <!-- <string>public.app-category.YOUR-CATEGORY-HERE</string> -->
	<key>UIDeviceFamily</key>
	<array>
		<integer>2</integer>
	</array>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.lifestyle</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>XSAppIconAssets</key>
	<string>Assets.xcassets/appicon.appiconset</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>BaristaNotes uses the microphone to capture voice commands for logging shots, navigating the app, and dictating tasting notes.</string>
	<key>NSCameraUsageDescription</key>
	<string>BaristaNotes uses the camera to capture photos of your espresso shots and coffee beans for visual reference.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>BaristaNotes accesses your photo library to attach images to shots and beans.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>BaristaNotes saves captured shot photos to your photo library.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>BaristaNotes uses speech recognition to convert your spoken commands into actions like logging a shot or navigating to a bean.</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Bluetooth is not used by BaristaNotes. This entry is required because the debug-only MAUI DevFlow diagnostic agent probes the Bluetooth subsystem at startup.</string>
</dict>
</plist>
